# ============================================
# ШАБЛОН переменных окружения.
# Скопируйте в .env и подставьте реальные значения.
# Файл .env в git НЕ попадает (см. .gitignore).
# ============================================

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_system
DB_USER=test_user
DB_PASSWORD=change_me

# Server
PORT=3001
NODE_ENV=production

# Security — ваш реальный домен после деплоя
ALLOWED_ORIGIN=https://example.com

# Admin (смените пароль при первом входе!)
ADMIN_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change_me
